@startuml

namespace Server {
    interface ServerConnection {
        +GetClientIdentity()
        +GetUserData()
        +Notify()
        +Reply()
        +RequestDisconnect()
    }
}

namespace Dispatch {
    namespace QNX {
        interface Client {
            +Connect()
            +SendMessage()
        }

        interface Server {
            +Dispatch()
            +Accept()
        }
    }

    namespace UnixDomain {
        interface Client {
            +Connect()
            +SendMessage()
        }

        interface Server {
            +Listen()
            +Accept()
        }
    }
}

interface IConnectionHandler <<user_provided>> {
    +OnMessage()
    +OnMessageWithReply()
    +OnDisconnect()
}

Server.ServerConnection ..> IConnectionHandler : uses

@enduml
