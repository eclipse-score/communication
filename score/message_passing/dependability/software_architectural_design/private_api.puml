@startuml

namespace Client {
    interface ClientDispatch {
        +Connect()
        +SendMessage()
    }

    interface ClientUnixDomain {
        +Connect()
        +SendMessage()
    }
}

namespace Server {
    interface ServerConnection {
        +GetClientIdentity()
        +GetUserData()
        +Notify()
        +Reply()
        +RequestDisconnect()
    }

    interface ServerDispatch {
        +Dispatch()
        +Accept()
    }

    interface ServerUnixDomain {
        +Listen()
        +Accept()
    }
}

interface IConnectionHandler <<user_provided>> {
    +OnMessage()
    +OnMessageWithReply()
    +OnDisconnect()
}

Server.ServerConnection ..> IConnectionHandler : uses

@enduml
