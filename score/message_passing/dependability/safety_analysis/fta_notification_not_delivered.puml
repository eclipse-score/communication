!include fta_metamodel.puml

$TopEvent("Server notification lost, incomplete, corrupted, delayed, or spurious", "MessagePassingFMEA.NotificationNotDelivered")

$OrGate("OG1", "MessagePassingFMEA.NotificationNotDelivered")

