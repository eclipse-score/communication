<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>CodeQL Findings Report</title>
<style>
:root { --bg: #1e1e2e; --surface: #2a2a3c; --text: #cdd6f4; --muted: #6c7086; --border: #45475a; }
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: var(--bg); color: var(--text); padding: 2rem; }
h1 { margin-bottom: 0.5rem; }
.meta { color: var(--muted); margin-bottom: 1.5rem; font-size: 0.9rem; }
.summary { display: flex; gap: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; }
.summary .card { background: var(--surface); border-radius: 8px; padding: 1rem 1.5rem; text-align: center; min-width: 120px; }
.summary .card .num { font-size: 2rem; font-weight: bold; }
.summary .card .label { color: var(--muted); font-size: 0.85rem; margin-top: 0.25rem; }
table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
thead th { background: var(--surface); position: sticky; top: 0; text-align: left; padding: 0.6rem 0.8rem; border-bottom: 2px solid var(--border); }
tbody td { padding: 0.5rem 0.8rem; border-bottom: 1px solid var(--border); vertical-align: top; }
tbody tr:hover { background: var(--surface); }
.sev-error { color: #e74c3c; font-weight: bold; }
.sev-warning { color: #e67e22; font-weight: bold; }
.sev-recommendation { color: #6c7086; }
.path { color: #89b4fa; word-break: break-all; }
.msg { max-width: 400px; }
.no-data { color: var(--muted); font-style: italic; margin-top: 2rem; }
</style>
</head>
<body>
<h1>CodeQL Findings Report</h1>
<p class="meta">Generated: {{ timestamp }}</p>

{% if findings %}
<div class="summary">
  <div class="card">
    <div class="num" style="color:{% if errors == 0 %}#27ae60{% else %}#e74c3c{% endif %}">{{ errors }}</div>
    <div class="label">Errors</div>
  </div>
  <div class="card">
    <div class="num" style="color:{% if warnings == 0 %}#27ae60{% else %}#e67e22{% endif %}">{{ warnings }}</div>
    <div class="label">Warnings</div>
  </div>
  <div class="card">
    <div class="num" style="color:var(--muted)">{{ recommendations }}</div>
    <div class="label">Recommendations</div>
  </div>
  <div class="card">
    <div class="num" style="color:var(--muted)">{{ total }}</div>
    <div class="label">Total</div>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th>Severity</th>
      <th>Rule</th>
      <th>Message</th>
      <th>File</th>
      <th>Line</th>
    </tr>
  </thead>
  <tbody>
    {% for f in findings %}
    <tr>
      <td class="sev-{{ f.severity }}">{{ f.severity | capitalize }}</td>
      <td>{{ f.name }}</td>
      <td class="msg">{{ f.message }}</td>
      <td class="path">{{ f.path }}</td>
      <td>{{ f.line }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="no-data">No CodeQL findings data available.</p>
{% endif %}
</body>
</html>
