build:with_debug_symbols --features=debug_symbols
build:with_debug_symbols --cxxopt -gline-tables-only
build:with_debug_symbols --cxxopt -gcolumn-info
build:with_debug_symbols --strip=never

build:sanitizer_common --extra_toolchains=@llvm_toolchain//:cc-toolchain-x86_64-linux
build:sanitizer_common --extra_toolchains=@ferrocene_x86_64_unknown_linux_gnu_llvm//:rust_ferrocene_toolchain
build:sanitizer_common --config=with_debug_symbols

build:asan --config=sanitizer_common
build:asan --features=score_asan
build:asan --@score_cpp_policies//sanitizers/flags:asan=True
build:asan --platform_suffix=asan
test:asan  --run_under=@score_cpp_policies//sanitizers:wrapper

build:ubsan --config=sanitizer_common
build:ubsan --features=score_ubsan
build:ubsan --@score_cpp_policies//sanitizers/flags:ubsan=True
build:ubsan --platform_suffix=ubsan
test:ubsan  --run_under=@score_cpp_policies//sanitizers:wrapper

build:lsan --config=sanitizer_common
build:lsan --features=score_lsan
build:lsan --@score_cpp_policies//sanitizers/flags:lsan=True
build:lsan --platform_suffix=lsan
test:lsan  --run_under=@score_cpp_policies//sanitizers:wrapper

build:tsan --config=sanitizer_common
build:tsan --features=score_tsan
build:tsan --@score_cpp_policies//sanitizers/flags:tsan=True
build:tsan --platform_suffix=tsan
test:tsan  --run_under=@score_cpp_policies//sanitizers:wrapper

build:asan_ubsan_lsan --config=asan
build:asan_ubsan_lsan --config=ubsan
build:asan_ubsan_lsan --config=lsan
build:asan_ubsan_lsan --platform_suffix=asan_ubsan_lsan

build:tsan_ubsan --config=tsan
build:tsan_ubsan --config=ubsan
build:tsan_ubsan --platform_suffix=tsan_ubsan
